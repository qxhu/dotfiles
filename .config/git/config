# Personal data (name, default email) lives in ~/.config/git/local — not tracked.
# That file is created by setup.sh on first run.
[user]
	useConfigOnly = true

[include]
	path = ~/.config/git/local

# qxhu identity for GitHub HTTPS and SSH remotes
[includeIf "hasconfig:remote.*.url:https://github.com/qxhu/**"]
	path = ~/.config/git/qxhu
[includeIf "hasconfig:remote.*.url:git@github.com:qxhu/**"]
	path = ~/.config/git/qxhu
[includeIf "hasconfig:remote.*.url:ssh://git@github.com/qxhu/**"]
	path = ~/.config/git/qxhu

[core]
	excludesfile = ~/.config/git/ignore
	pager = delta

[interactive]
	diffFilter = delta --color-only

[delta]
	navigate = true
	side-by-side = true
	line-numbers = true

[pull]
	rebase = true

[init]
	defaultBranch = main
