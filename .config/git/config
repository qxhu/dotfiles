# Personal data (name, default email) lives in ~/.config/git/local — not tracked.
# That file is created by setup.sh on first run.
[include]
	path = ~/.config/git/local

# qxhu identity — any repo whose remote URL contains "qxhu/"
[includeIf "hasconfig:remote.*.url:*qxhu/*"]
	path = ~/.config/git/qxhu

# qxhu identity — any repo whose remote URL contains "qxhu/"
[includeIf "hasconfig:remote.*.url:*qxhu/*"]
	path = ~/.config/git/qxhu

[core]
	excludesfile = ~/.config/git/ignore

[pull]
	rebase = true

[init]
	defaultBranch = main
