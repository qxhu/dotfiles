# Personal data (name, default email) lives in ~/.config/git/local — not tracked.
# That file is created by setup.sh on first run.
[include]
	path = ~/.config/git/local

# Littleist identity — any repo whose remote URL contains "littleist/"
[includeIf "hasconfig:remote.*.url:*littleist/*"]
	path = ~/.config/git/littleist

# qxhu identity — any repo whose remote URL contains "qxhu/"
[includeIf "hasconfig:remote.*.url:*qxhu/*"]
	path = ~/.config/git/qxhu

[core]
	excludesfile = ~/.config/git/ignore
	pager = delta

[interactive]
	diffFilter = delta --color-only

[delta]
	navigate = true
	side-by-side = true
	line-numbers = true

[pull]
	rebase = true

[init]
	defaultBranch = main
