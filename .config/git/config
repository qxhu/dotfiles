# Single identity for every repo: qxhu / GitHub no-reply, signed with the
# 1Password SSH key. Add an includeIf below if a host ever needs a different
# email (e.g. a work org that mandates a corporate address).
[user]
	name = qxhu
	email = 67043+qxhu@users.noreply.github.com
	signingKey = ~/.config/git/qxhu-signing.pub
	useConfigOnly = true

# Sign all commits and tags with the 1Password SSH key.
[gpg]
	format = ssh
[gpg "ssh"]
	program = /Applications/1Password.app/Contents/MacOS/op-ssh-sign
	allowedSignersFile = ~/.config/git/allowed_signers
[commit]
	gpgSign = true
[tag]
	gpgSign = true

[core]
	excludesfile = ~/.config/git/ignore
	pager = delta

[interactive]
	diffFilter = delta --color-only

[delta]
	navigate = true
	side-by-side = true
	line-numbers = true

[pull]
	rebase = true

[init]
	defaultBranch = main
